<tr>
  <td class="fw-semibold">$id</td>
  <td>$tracker</td>
  <td>$status</td>
  <td>$assigned_to</td>
</tr>
<tr class="issue-subject">
  <td>
    <a href="javascript:openTask('$id','$subject','$project');" title="Open task">
      <i class="fa-regular fa-pencil-square me-1"></i>Open
    </a>
  </td>
  <td colspan="3">
    <a href="$RedmineURL/issues/$id" target="_blank">$subject</a>
  </td>
</tr>
